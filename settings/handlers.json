  {
    "name": "oks-pdf",
    "level": 1,
    "description": "PDF → MinerU layout output + page/formula/asset evidence Raw Bundle",
    "check_argv": ["{mineru_cli}", "--version"],
    "install_hint": "Install scripts/mineru_extract_requirements.txt and configure settings/raw-tools.json",
    "modalities": ["pdf"],
    "raw_subdir": "papers",
    "json_protocol": true,
    "output_contract": "raw-multimodal/v0.1",
    "tool_config": "settings/raw-tools.json",
    "command_argv_sequence": [
      ["{mineru_cli}", "-p", "{input}", "-o", "{work_dir}", "-m", "auto", "-b", "pipeline"],
      ["{mineru_python}", "scripts/raw_bundle_adapter.py", "mineru", "{mineru_result}", "--source", "{input}", "--output", "{output}"]
    ]
  },
  {
